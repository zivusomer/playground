{
  "name": "playground",
  "version": "1.0.0",
  "description": "Node.js API with /hello endpoint",
  "main": "dist/index.js",
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "del": "^6.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "gulp": "^4.0.2",
    "gulp-typescript": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1"
  },
  "scripts": {
    "lint": "eslint src test --fix && prettier src test --write",
    "gulp": "gulp",
    "build": "gulp build",
    "clean": "gulp clean",
    "start": "gulp && node --inspect dist/index.js",
    "dev": "ts-node --watch src/index.ts",
    "test": "node -r ts-node/register --test test/helloWorld.test.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": ["prettier --write", "eslint --fix"]
  }
}
